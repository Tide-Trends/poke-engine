{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Poke Engine GUI",
  "version": "0.1.0",
  "identifier": "com.tide-trends.poke-engine-gui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Poke Engine GUI",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
